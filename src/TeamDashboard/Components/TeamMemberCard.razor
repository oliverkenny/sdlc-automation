@using TeamDashboard.Models

<div class="team-card">
    <div class="card-avatar">
        <span>@Member.Initials</span>
    </div>
    <div class="card-info">
        <h5 class="card-name">@Member.Name</h5>
        <p class="card-role">@(string.IsNullOrWhiteSpace(Member.Role) ? "No role assigned" : Member.Role)</p>
    </div>
    <div class="card-status">
        <span class="status-indicator @GetStatusClass()"></span>
        <select class="status-select" value="@Member.Status" @onchange="OnStatusChanged">
            <option value="Available">Available</option>
            <option value="In Meeting">In Meeting</option>
            <option value="Focussing">Focussing</option>
            <option value="Away">Away</option>
        </select>
    </div>
</div>

@code {
    [Parameter]
    public TeamMember Member { get; set; } = default!;

    [Parameter]
    public EventCallback<string> OnStatusChange { get; set; }

    private string GetStatusClass() => Member.Status switch
    {
        "Available" => "status-available",
        "In Meeting" => "status-meeting",
        "Focussing" => "status-focussing",
        "Away" => "status-away",
        _ => "status-away"
    };

    private async Task OnStatusChanged(ChangeEventArgs e)
    {
        var newStatus = e.Value?.ToString() ?? "Available";
        Member.Status = newStatus;
        await OnStatusChange.InvokeAsync(newStatus);
    }
}
