@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<div class="page">
    <div class="sidebar"><NavMenu /></div>
    <main>
        <div class="top-row px-4"><h4 class="mb-0">Team Dashboard</h4></div>
        <article class="content px-4">
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent>
                    <div class="alert alert-danger" role="alert">
                        <p>Sorry, something went wrong while loading this page.</p>
                        <button type="button" class="btn btn-link p-0" @onclick="ReloadPage">Reload the page</button>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </article>
    </main>

    <ToastContainer />
</div>

@code {
    private void ReloadPage()
    {
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }
}
